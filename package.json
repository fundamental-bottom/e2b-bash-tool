{
  "name": "@funda-ai/e2b-bash-tool",
  "publishConfig": {
    "access": "public"
  },
  "version": "2.1.1",
  "description": "Generic bash tool for AI agents, compatible with AI SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && sed '1,/^-->/d' AGENTS.npm.md > dist/AGENTS.md",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.examples.json",
    "test": "vitest --exclude 'src/tool.e2b.integration.test.ts'",
    "test:run": "vitest run --exclude 'src/tool.e2b.integration.test.ts'",
    "test:e2b": "vitest run src/tool.e2b.integration.test.ts --sequence.concurrent",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "knip": "knip",
    "validate": "pnpm run lint && pnpm run knip && pnpm run typecheck && pnpm run build && pnpm run test:run",
    "prepublishOnly": "pnpm run validate && pnpm run build",
    "release": "bumpp"
  },
  "keywords": [
    "bash",
    "ai",
    "tool",
    "agent",
    "ai-sdk",
    "sandbox",
    "e2b"
  ],
  "author": "Funda AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fundamental-bottom/e2b-bash-tool.git"
  },
  "bugs": {
    "url": "https://github.com/fundamental-bottom/e2b-bash-tool/issues"
  },
  "homepage": "https://github.com/fundamental-bottom/e2b-bash-tool#readme",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "just-bash": "^2.10.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.85",
    "@azure/storage-blob": "^12.31.0",
    "@biomejs/biome": "^2.3.11",
    "@e2b/code-interpreter": "^1.0.0",
    "@types/node": "^22.10.0",
    "ai": "^6.0.13",
    "bumpp": "^11.0.1",
    "knip": "^5.80.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "@e2b/code-interpreter": "*",
    "ai": "^6.0.0",
    "just-bash": "^2.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "peerDependenciesMeta": {
    "just-bash": {
      "optional": true
    },
    "@e2b/code-interpreter": {
      "optional": true
    }
  }
}
